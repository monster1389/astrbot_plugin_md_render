{
  "渲染": {
    "type": "object",
    "description": "渲染",
    "hint": "将 Markdown 代码块、表格、数学表达式渲染为图片。",
    "items": {
      "代码块": {
        "type": "string",
        "description": "代码块处理",
        "options": ["不处理", "渲染图像", "渲染且保留原文", "渲染且md文件", "仅md文件"],
        "default": "渲染且md文件"
      },
      "表格": {
        "type": "string",
        "description": "表格处理",
        "options": ["不处理", "渲染图像", "渲染且保留原文", "渲染且md文件", "仅md文件"],
        "default": "渲染图像"
      },
      "表达式": {
        "type": "string",
        "description": "数学表达式处理",
        "options": ["不处理", "渲染图像", "渲染且保留原文"],
        "default": "渲染图像"
      },
      "分隔线": {
        "type": "string",
        "description": "分隔线 --- 处理",
        "options": ["不处理", "切分"],
        "default": "不处理"
      },
      "字体颜色": {
        "type": "string",
        "description": "渲染字体颜色",
        "options": ["#9CDCFE (浅蓝)", "#ABB2BF (material 默认)", "#D4D4D4 (浅灰)", "#FFFFFF (纯白)"],
        "default": "#9CDCFE (浅蓝)"
      },
      "背景颜色": {
        "type": "string",
        "description": "渲染背景颜色",
        "options": ["#1E1E1E (VS Code 深色)", "#2D2D2D (浅深色)", "#000000 (纯黑)", "#FFFFFF (纯白)"],
        "default": "#1E1E1E (VS Code 深色)"
      },
      "临时文件存活": {
        "type": "int",
        "description": "临时文件存活时长（分钟）",
        "default": 0,
        "hint": "0=即时删除, -1=永久保留"
      }
    }
  },
  "清洗": {
    "type": "object",
    "description": "清洗",
    "hint": "去除未渲染的 Markdown 格式标记，让纯文本消息更干净。",
    "items": {
      "加粗": { "type": "bool", "description": "去除 ** 标记", "default": true },
      "斜体": { "type": "bool", "description": "去除 * 标记", "default": true },
      "删除线": { "type": "bool", "description": "去除 ~~ 标记", "default": true },
      "行内代码": { "type": "bool", "description": "去除 ` 标记", "default": true },
      "链接": { "type": "bool", "description": "去除 [文字](url) 转为 文字 (url) 格式", "default": true },
      "标题": { "type": "bool", "description": "去除行首 # 标记", "default": true },
      "列表标记（无序）": { "type": "bool", "description": "去除 - 无序列表前缀标记", "default": true },
      "列表标记（有序）": { "type": "bool", "description": "去除 1. 有序列表前缀标记", "default": true },
      "引用": { "type": "bool", "description": "去除 > 引用标记", "default": true },
      "图片": { "type": "bool", "description": "去除 ![alt](url) 语法，转为 alt (url) 格式", "default": true }
    }
  }
}
