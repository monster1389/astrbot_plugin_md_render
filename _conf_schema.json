{
  "渲染": {
    "type": "object",
    "description": "渲染",
    "hint": "将 Markdown 代码块、表格、数学表达式渲染为图片。",
    "items": {
      "代码块": {
        "type": "string",
        "description": "代码块",
        "hint": "将围栏代码块渲染为图片，'仅md文件' 不渲染只发 .md。",
        "options": ["不处理", "渲染图像", "渲染且保留原文", "渲染且md文件", "仅md文件"],
        "default": "渲染且md文件"
      },
      "表格": {
        "type": "string",
        "description": "表格",
        "hint": "将 Markdown 表格渲染为图片，支持格内加粗、斜体、删除线、行内代码、链接。",
        "options": ["不处理", "渲染图像", "渲染且保留原文", "渲染且md文件", "仅md文件"],
        "default": "渲染图像"
      },
      "表达式": {
        "type": "string",
        "description": "数学表达式",
        "hint": "将 $...$ 行内和 $$...$$ 块级 LaTeX 表达式渲染为图片。",
        "options": ["不处理", "渲染图像", "渲染且保留原文"],
        "default": "渲染图像"
      },
      "分隔线": {
        "type": "string",
        "description": "分隔线",
        "hint": "对 --- 分隔线的处理方式。'切分' 可供分片插件使用。",
        "options": ["不处理", "切分"],
        "default": "不处理"
      },
      "临时文件存活": {
        "type": "int",
        "description": "临时文件存活",
        "hint": "渲染产物保留时长（分钟）。0=即时删除，-1=永久保留。",
        "default": 0
      }
    }
  },
  "清洗": {
    "type": "object",
    "description": "清洗",
    "hint": "去除未渲染的 Markdown 格式标记，让纯文本消息更干净。",
    "items": {
      "加粗": { "type": "bool", "description": "加粗", "hint": "去除 **text** 标记，保留文本。", "default": true },
      "斜体": { "type": "bool", "description": "斜体", "hint": "去除 *text* 标记，保留文本。", "default": true },
      "删除线": { "type": "bool", "description": "删除线", "hint": "去除 ~~text~~ 标记，保留文本。", "default": true },
      "行内代码": { "type": "bool", "description": "行内代码", "hint": "去除 `text` 标记，保留文本。", "default": true },
      "链接": { "type": "bool", "description": "链接", "hint": "将 [text](url) 转为 'text (url)' 格式。", "default": true },
      "标题": { "type": "bool", "description": "标题", "hint": "去除行首 # 标记，保留文本。", "default": true },
      "列表标记（无序）": { "type": "bool", "description": "无序列表", "hint": "去除 - 无序列表前缀标记。", "default": true },
      "列表标记（有序）": { "type": "bool", "description": "有序列表", "hint": "去除 1. 有序列表前缀标记。", "default": true },
      "引用": { "type": "bool", "description": "引用", "hint": "去除 > 引用前缀标记。", "default": true },
      "图片": { "type": "bool", "description": "图片", "hint": "将 ![alt](url) 转为 'alt (url)' 格式。", "default": true },
      "代码块": { "type": "bool", "description": "代码块", "hint": "去除 ``` 围栏标记，保留代码文本。", "default": false },
      "表格": { "type": "bool", "description": "表格", "hint": "去除表头分隔行，竖线保留为列分隔符。", "default": false },
      "表达式": { "type": "bool", "description": "表达式", "hint": "去除 $ 和 $$ 定界符，保留公式文本。", "default": false }
    }
  }
}
